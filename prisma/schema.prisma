generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

/// *
///  * Client model - Core entity representing a customer/client
///  * Tracks all client information and health status
model Client {
  id                  String        @id @default(cuid())
  name                String        @db.VarChar(255)
  email               String        @unique @db.VarChar(255)
  phone               String?       @db.VarChar(20)
  company             String?       @db.VarChar(255)
  services            String[]      @default([])
  healthStatus        HealthStatus  @default(GREEN)
  lastInteractionDate DateTime?
  nextFollowUpDate    DateTime?
  notes               String?
  tags                String[]      @default([])
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  complaints          Complaint[]
  followUps           FollowUp[]
  interactions        Interaction[]

  @@index([healthStatus])
  @@index([lastInteractionDate])
  @@index([nextFollowUpDate])
}

/// *
///  * Interaction model - Complete history of all client communications
///  * Stores calls, messages, emails, and meetings
///  * Ensures no more "Wait... what did this client say again?"
model Interaction {
  id              String          @id @default(cuid())
  clientId        String
  type            InteractionType
  subject         String?         @db.VarChar(255)
  content         String
  handledBy       String          @db.VarChar(255)
  sentiment       Sentiment       @default(NEUTRAL)
  keyPoints       String[]        @default([])
  suggestedAction String?
  createdAt       DateTime        @default(now())
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([type])
  @@index([sentiment])
}

/// *
///  * Complaint model - Logs every issue and tracks resolution
///  * Sends reminders until resolved - ensures nothing falls through cracks
model Complaint {
  id               String            @id @default(cuid())
  clientId         String
  title            String            @db.VarChar(255)
  description      String
  category         ComplaintCategory
  status           ComplaintStatus   @default(PENDING)
  priority         Priority          @default(MEDIUM)
  assignedTo       String?           @db.VarChar(255)
  resolutionNotes  String?
  resolvedAt       DateTime?
  lastReminderSent DateTime?
  reminderCount    Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
}

/// *
///  * FollowUp model - Automatically reminds staff to check on clients
///  * Sends WhatsApp/SMS follow-ups automatically
///  * Ensures consistent, timely engagement
model FollowUp {
  id              String              @id @default(cuid())
  clientId        String
  title           String              @db.VarChar(255)
  description     String?
  scheduledFor    DateTime
  status          FollowUpStatus      @default(PENDING)
  method          CommunicationMethod @default(EMAIL)
  messageTemplate String?
  completedAt     DateTime?
  completedBy     String?             @db.VarChar(255)
  reminderSentAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([scheduledFor])
  @@index([status])
}

/// *
///  * AIInsight model - AI-generated suggestions for staff
///  * Suggests what to say, when to follow up, which clients are at risk
///  * Your secret weapon for proactive client management
model AIInsight {
  id              String      @id @default(cuid())
  clientId        String?
  type            InsightType
  title           String      @db.VarChar(255)
  description     String
  suggestedAction String?
  confidence      Int         @default(75)
  actedUpon       Boolean     @default(false)
  createdAt       DateTime    @default(now())

  @@index([type])
  @@index([actedUpon])
}

/// *
///  * ClientMetric model - Tracks metrics for dashboard visualization
///  * Enables the Client Health Dashboard (Green/Yellow/Red)
model ClientMetric {
  id                  String   @id @default(cuid())
  clientId            String   @unique
  totalInteractions   Int      @default(0)
  lastInteractionDays Int?
  openComplaints      Int      @default(0)
  resolvedComplaints  Int      @default(0)
  pendingFollowUps    Int      @default(0)
  completedFollowUps  Int      @default(0)
  healthScore         Int      @default(75)
  churnRisk           Int      @default(0)
  updatedAt           DateTime @updatedAt

  @@index([healthScore])
  @@index([churnRisk])
}

/// *
///  * TeamMember model - Tracks staff and their responsibilities
///  * Manages who handles which clients and tasks
model TeamMember {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  role      String   @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  whatsapp  String?  @db.VarChar(20)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// *
///  * AutomationRule model - Defines rules for automated actions
///  * Enables smart follow-ups and reminders without manual intervention
model AutomationRule {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  description String?
  trigger     String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// *
///  * Health status enum for client status tracking
///  * Used to identify at-risk clients and prioritize follow-ups
enum HealthStatus {
  GREEN
  YELLOW
  RED
}

/// *
///  * Interaction type enum - categorizes different communication methods
enum InteractionType {
  CALL
  EMAIL
  SMS
  WHATSAPP
  MEETING
  NOTE
  FEEDBACK
}

/// *
///  * Sentiment enum - AI analysis of interaction tone
enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// *
///  * Complaint category enum - categorizes types of issues
enum ComplaintCategory {
  PRODUCT_QUALITY
  SERVICE_DELIVERY
  BILLING
  SUPPORT
  DELIVERY
  OTHER
}

/// *
///  * Complaint status enum - tracks resolution progress
enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  URGENT
}

/// *
///  * Priority enum - determines urgency of action
enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// *
///  * Follow-up status enum - tracks follow-up progress
enum FollowUpStatus {
  PENDING
  SENT
  COMPLETED
  SKIPPED
}

/// *
///  * Communication method enum - how to reach the client
enum CommunicationMethod {
  EMAIL
  SMS
  WHATSAPP
  CALL
  IN_PERSON
}

/// *
///  * Insight type enum - categorizes AI suggestions
enum InsightType {
  AT_RISK_CLIENT
  FOLLOW_UP_REMINDER
  SUGGESTED_MESSAGE
  COMPLAINT_ALERT
  ENGAGEMENT_OPPORTUNITY
  CHURN_PREDICTION
}
